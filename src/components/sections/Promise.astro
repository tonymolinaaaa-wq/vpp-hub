---
// Promise.astro — Section #2 of the homepage architecture.
// Ink background, Bone text. Five cards documenting the VPP Promise
// (per /docs/brand-brief-v2.md Section 07).

interface PromiseItem {
  number: string;
  titleBefore: string;
  titleAccent: string;
  titleAfter: string;
  body: string;
}

const items: PromiseItem[] = [
  {
    number: '01',
    titleBefore: '$300/Day ',
    titleAccent: 'Finish',
    titleAfter: ' Promise',
    body: 'Every VPP contract carries a written completion deadline. If we miss it, you get $300 a day back until the job is done. In writing. Every time.',
  },
  {
    number: '02',
    titleBefore: 'HOA ',
    titleAccent: 'Champion',
    titleAfter: ' Service',
    body: 'We handle the entire HOA Architectural Review submission and approval for exterior repaints. Free. One resubmission included if the first proposal is denied.',
  },
  {
    number: '03',
    titleBefore: '',
    titleAccent: 'Daily',
    titleAfter: ' Photo Updates',
    body: 'Four milestone photos every working day, sent by text: morning arrival, prep complete, paint in progress, end-of-day cleanup. You know what’s happening while you’re at work.',
  },
  {
    number: '04',
    titleBefore: '',
    titleAccent: 'Lifetime',
    titleAfter: ' Touch-Up Kit',
    body: 'At job completion, you keep a labeled, sealed kit with one quart of each color used, a brush, and a written log of which color went where. Lifetime use.',
  },
  {
    number: '05',
    titleBefore: '12-Month ',
    titleAccent: 'Wellness',
    titleAfter: ' Check',
    body: 'Exactly one year after completion, we return for a free 30-minute walkthrough. Any small workmanship issues are touched up free.',
  },
];
---

<section class="promise">
  <div class="promise__container">
    <header class="promise__heading">
      <p class="promise__eyebrow">THE VPP PROMISE</p>
      <h2 class="promise__title">
        Five things. In <span class="promise__title-accent">writing</span>. On every contract.
      </h2>
    </header>

    <ul class="promise__cards" role="list">
      {items.map((item) => (
        <li class="promise-card">
          <p class="promise-card__number">{item.number}</p>
          <h3 class="promise-card__title">
            {item.titleBefore}<span class="promise-card__title-accent">{item.titleAccent}</span>{item.titleAfter}
          </h3>
          <p class="promise-card__body">{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .promise {
    background-color: var(--vpp-ink);
    color: var(--vpp-bone);
    padding-top: var(--vpp-space-8);
    padding-bottom: var(--vpp-space-8);
  }

  .promise__container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: var(--vpp-space-3);
    padding-right: var(--vpp-space-3);
  }

  .promise__heading {
    margin: 0 0 var(--vpp-space-8) 0;
  }

  .promise__eyebrow {
    margin: 0 0 var(--vpp-space-2) 0;
    font-family: var(--vpp-font-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--vpp-rule);
    text-transform: uppercase;
    line-height: 1.3;
  }

  .promise__title {
    margin: 0;
    font-family: var(--vpp-font-display);
    font-weight: 900;
    letter-spacing: -0.01em;
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.1;
    color: var(--vpp-bone);
    text-wrap: balance;
  }

  .promise__title-accent {
    color: var(--vpp-signal);
  }

  /* Card grid */
  .promise__cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--vpp-space-3);
  }

  .promise-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--vpp-space-2);
    border: 1px solid var(--vpp-mid);
    border-radius: var(--vpp-radius);
    padding: var(--vpp-space-4);
    background-color: transparent;
  }

  .promise-card__number {
    margin: 0;
    font-family: var(--vpp-font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--vpp-rule);
    text-transform: uppercase;
    line-height: 1;
  }

  .promise-card__title {
    margin: 0;
    font-family: var(--vpp-font-display);
    font-weight: 900;
    letter-spacing: -0.01em;
    font-size: 20px;
    line-height: 1.15;
    color: var(--vpp-bone);
    text-transform: none;
  }

  .promise-card__title-accent {
    color: var(--vpp-signal);
  }

  .promise-card__body {
    margin: 0;
    font-family: var(--vpp-font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.45;
    color: var(--vpp-bone);
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    .promise {
      padding-top: var(--vpp-space-12);
      padding-bottom: var(--vpp-space-12);
    }

    .promise__container {
      padding-left: var(--vpp-space-5);
      padding-right: var(--vpp-space-5);
    }

    .promise__eyebrow {
      font-size: 14px;
    }

    .promise__cards {
      flex-direction: row;
      gap: var(--vpp-space-3);
    }

    .promise-card {
      flex: 1 1 0;
      min-width: 0;
      padding: var(--vpp-space-3);
    }

    .promise-card__title {
      font-size: 18px;
    }
  }

  @media (min-width: 1024px) {
    .promise-card {
      padding: var(--vpp-space-4);
    }

    .promise-card__title {
      font-size: 22px;
    }

    .promise-card__body {
      font-size: 15px;
    }
  }
</style>
